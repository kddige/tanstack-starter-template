# Optional Redis connection for future caching, rate limiting, queues, or Better Auth secondary storage.
# Remove REDIS_URL from src/env.ts and docker-compose.yml if your app does not need Redis.
REDIS_URL=redis://localhost:6379

# Local host connection for the PostgreSQL service in docker-compose.yml.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Generate with: bunx --bun @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000 # Base URL of the app

VITE_APP_TITLE="Tanstack Starter Template"
